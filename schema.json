{
  "type": "object",
  "properties": {
    "text": {
      "type": "string"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["image", "video", "audio", "documents", "location"]
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "description": {
            "type": "string",
            "maxLength": 1024
          },
          "address": {
            "type": "string",
            "maxLength": 1024
          }
        },
        "required": ["type"],
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "location"
                }
              }
            },
            "then": {
              "required": ["latitude", "longitude"]
            },
            "else": {
              "required": ["url"]
            }
          }
        ]
      }
    }
  },
  "required": ["text", "attachments"]
}
