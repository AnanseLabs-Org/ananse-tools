        "jsCode": "let output = $input.item.json.output;\nlet parsed = { text: output, attachments: [] };\ntry {\n  let cleanOutput = output.trim();\n  if (cleanOutput.startsWith(\"```json\")) {\n    cleanOutput = cleanOutput.substring(7);\n  }\n  if (cleanOutput.endsWith(\"```\")) {\n    cleanOutput = cleanOutput.substring(0, cleanOutput.length - 3);\n  }\n  parsed = JSON.parse(cleanOutput.trim());\n} catch (e) {\n  parsed = { text: output, attachments: [] };\n}\nreturn parsed;"
