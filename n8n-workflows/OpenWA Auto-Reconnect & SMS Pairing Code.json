{
  "name": "OpenWA Auto-Reconnect & SMS Pairing Code",
  "nodes": [
    {
      "parameters": {},
      "name": "Webhook",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        -400,
        32
      ],
      "id": "8c088457-92c3-4d4c-a0bd-c968cdb83c3d"
    },
    {
      "parameters": {
        "dataType": "string",
        "value1": "={{$json.body.data.status}}",
        "rules": {
          "rules": [
            {
              "operation": "equal",
              "value2": "disconnected",
              "output": 0
            },
            {
              "operation": "equal",
              "value2": "qr_ready",
              "output": 1
            }
          ]
        }
      },
      "name": "Route by Session Status",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [
        -200,
        32
      ],
      "id": "dc9952bf-6e9e-4903-b341-614da0bd374e"
    },
    {
      "parameters": {
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
