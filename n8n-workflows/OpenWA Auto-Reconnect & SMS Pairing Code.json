            }
          ]
        }
      },
      "name": "Request Pairing Code",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 2,
      "position": [
        50,
        100
      ],
      "id": "787d0729-720b-4ea1-9b12-003d02f11395",
      "credentials": {
        "httpHeaderAuth": {
          "id": "oAHp8tvD9riiKG8g",
          "name": "Header Auth account WA"
        }
      }
    },
    {
      "parameters": {
        "authentication": "genericCredentialType",
